# MongoDB 数据库配置
MONGODB_URI=mongodb://127.0.0.1:27017/xiaohongshu_audit

# JWT 密钥（必须至少32个字符，用于生成访问令牌）
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# 服务端口
PORT=5000

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,https://www.wubug.cc,https://wubug.cc

# ====================
# 阿里云OSS配置（图片存储）
# ====================
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_REGION=oss-cn-shenzhen

# ====================
# 微信小程序配置
# ====================
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# ====================
# AI 服务配置
# ====================
# DeepSeek API 密钥（必需）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key

# AI 服务选择 (deepseek 或 zai，默认: deepseek)
AI_PROVIDER=deepseek

# AI 余额监控配置
AI_LOW_BALANCE_THRESHOLD=5
AI_AUTO_SWITCH=true

# 备用 AI 服务（智谱 AI）
ZAI_API_KEY=your_zai_api_key

# ====================
# 小红书 Cookie 配置（用于评论验证）
# ====================
# 获取方式：浏览器 F12 → Network → Request Headers → Cookie
# 必须包含：a1, web_session, id_token, loadts
XIAOHONGSHU_COOKIE=your_xiaohongshu_cookie_here

# ====================
# 支付配置（如需要）
# ====================
# ALIPAY_APP_ID=your_alipay_app_id
# ALIPAY_PRIVATE_KEY=your_alipay_private_key
# ALIPAY_PUBLIC_KEY=your_alipay_public_key
