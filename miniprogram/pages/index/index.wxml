<!-- pages/index/index.wxml -->
<scroll-view class="container" scroll-y="true" enable-flex="true" bindscrolltolower="onScrollToLower" refresher-enabled="{{true}}" bindrefresherrefresh="onPullDownRefresh" bindrefresherrestore="onPullDownRefreshRestore">

  <!-- 🔒 内部员工使用说明 -->
  <view class="internal-notice">
    <view class="notice-content">
      <text class="notice-icon">🔒</text>
      <text class="notice-text">本小程序仅限内部员工使用，已进行账号鉴权验证</text>
    </view>
  </view>

  <!-- 简化的用户信息头图 -->
  <view class="header-card">
    <view class="user-info">
      <view class="avatar-container">
        <image class="avatar" src="{{userInfo.avatar || userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="cover"></image>
      </view>
      <view class="user-text">
        <view class="greeting">你好，{{userInfo.nickname || userInfo.nickName || '奋斗者'}}</view>
        <view class="subtitle">{{userInfo.phone ? '今天也是努力搞积分的一天！💪' : '请先完成手机号授权'}}</view>
      </view>
    </view>
  </view>

  <!-- 审核员在线状态 -->
  <view class="auditor-status-card">
    <view class="auditor-info">
      <view class="auditor-item">
        <text class="auditor-label">审核员</text>
        <text class="auditor-count">{{auditorStatus.totalAuditors || 0}} 人</text>
      </view>
      <view class="auditor-divider"></view>
      <view class="auditor-item">
        <text class="auditor-label">在线</text>
        <text class="auditor-count online">{{auditorStatus.onlineAuditors || 0}} 人</text>
      </view>
    </view>
  </view>

  <!-- 公告栏（滚动显示多条公告） -->
  <!-- <view class="announcement-container" wx:if="{{announcements.length > 0}}">
    <view class="announcement-icon">📢</view>
    <swiper class="announcement-swiper"
      indicator-dots="{{false}}"
      autoplay="{{true}}"
      interval="3000"
      duration="500"
      circular="{{true}}"
      vertical="{{true}}"
      display-multiple-items="{{1}}">
      <block wx:for="{{announcements}}" wx:key="id">
        <swiper-item class="announcement-item" bindtap="handleAnnouncementTap" data-item="{{item}}">
          <view class="announcement-title" style="color: {{item.textColor || '#ffffff'}}; font-size: {{item.fontSize || 28}}rpx;">{{item.title}}</view>
          <view class="announcement-content" style="color: {{item.textColor || '#ffffff'}}; font-size: {{(item.fontSize || 28) - 4}}rpx;">{{item.content}}</view>
        </swiper-item>
      </block>
    </swiper>
  </view> -->

  <!-- 📋 设备审核状态卡片 -->
  <view class="device-review-card" wx:if="{{showDeviceReviewCard}}">
    <view class="card-header">
      <text class="card-title">📱 设备审核状态</text>
    </view>
    <view class="card-content">
      <view class="review-info">
        <view class="device-name">设备: {{deviceReviewStatus.accountName || '未知设备'}}</view>
        <view class="review-status {{deviceReviewStatus.status}}">
          状态:
          {{
            deviceReviewStatus.status === 'pending' ? '待审核' :
            deviceReviewStatus.status === 'ai_approved' ? 'AI审核通过，等待人工审核' :
            deviceReviewStatus.status === 'approved' ? '审核通过' :
            deviceReviewStatus.status === 'rejected' ? '审核拒绝' : '审核中'
          }}
        </view>
        <view class="review-time" wx:if="{{deviceReviewStatus.createdAt}}">
          提交时间: {{deviceReviewStatus.createdAt}}
        </view>
        <view class="review-reason" wx:if="{{deviceReviewStatus.status === 'rejected' && deviceReviewStatus.reviewReason}}">
          拒绝原因: {{deviceReviewStatus.reviewReason}}
        </view>
      </view>
      <view class="review-actions" wx:if="{{deviceReviewStatus.status === 'rejected'}}">
        <button class="retry-btn" bindtap="goToDeviceList">重新提交</button>
      </view>
    </view>
  </view>

  <!-- 📋 审核记录列表 -->
  <view class="list-container">
    <view class="list-header">近期审核记录</view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && reviews.length === 0}}">
      <image class="empty-icon" src="https://img.icons8.com/ios/100/cccccc/empty-box.png" mode="widthFix"></image>
      <text>暂无记录，快去上传第一单吧~</text>
      <button class="go-upload-btn" bindtap="goToUpload">去上传</button>
    </view>

    <!-- 列表内容 -->
    <block wx:for="{{reviews}}" wx:key="_id">

      <!-- 持续检查奖励卡片 -->
      <view class="review-card continuous-check-card" wx:if="{{item.isContinuousCheckReward}}">
        <view class="card-thumb-container continuous-check-thumb">
          <text class="continuous-check-icon">🎁</text>
        </view>
        <view class="card-content">
          <view class="card-row">
            <text class="task-type continuous-check-type">笔记持续存在</text>
            <view class="status-tag completed">已完成</view>
          </view>
          <view class="card-row time-row">
            <text class="submit-time">{{item.continuousCheckInfo.checkTime}}</text>
            <text class="amount continuous-amount">+{{item.continuousCheckInfo.rewardPoints}} 积分</text>
          </view>
          <view class="continuous-check-badge">
            <text>第 {{item.continuousCheckInfo.checkIndex}} 次检查奖励</text>
          </view>
        </view>
      </view>

      <!-- 普通审核卡片 -->
      <view class="review-card" wx:else>
        <view class="card-thumb-container">
          <image class="card-thumb" src="{{item.imageUrl}}" mode="aspectFill"></image>
          <view class="completion-icon" wx:if="{{item.status === 'manager_approved' || item.status === 'completed'}}">✓</view>
          <view class="rejection-icon" wx:if="{{item.status === 'rejected' || item.status === 'manager_rejected' || item.status === 'client_verification_failed'}}">✗</view>
        </view>
        <view class="card-content">
          <view class="card-row">
            <text class="task-type">{{item.imageType === 'customer_resource' ? '客资' : (item.imageType === 'note' ? '笔记' : '评论')}}</text>
            <view class="status-tag {{(item.aiReviewResult && item.aiReviewResult.passed === false) ? 'rejected' : item.status}}">
              {{
                item.status === 'completed' ? '已到账' :
                ((item.status === 'rejected' || item.status === 'manager_rejected' || (item.aiReviewResult && item.aiReviewResult.passed === false)) ? '已驳回' :
                (item.status === 'manager_approved' ? '审核通过' :
                (item.status === 'mentor_approved' ? '主管审核中' : '审核中')))
              }}
            </view>
          </view>
          <view class="card-row time-row">
            <text class="submit-time">{{item.formattedTime}}</text>
            <text class="amount" wx:if="{{item.status === 'manager_approved' || item.status === 'completed'}}">+ {{item.snapshotPrice}}</text>
          </view>

          <!-- 评论昵称和内容 -->
          <view class="card-row info-row" wx:if="{{item.imageType === 'comment'}}">
            <text class="info-label">昵称:</text>
            <text class="info-value">{{item.commentAuthor || '未知'}}</text>
          </view>
          <view class="card-row info-row" wx:if="{{item.imageType === 'comment' && item.userNoteInfo.comment}}">
            <text class="info-label">评论:</text>
            <text class="info-value comment-content">{{item.userNoteInfo.comment}}</text>
          </view>

          <!-- 笔记标题和作者 -->
          <view class="card-row info-row" wx:if="{{item.imageType === 'note'}}">
            <text class="info-label">标题:</text>
            <text class="info-value">{{item.userNoteInfo.title || '未知'}}</text>
          </view>
          <view class="card-row info-row" wx:if="{{item.imageType === 'note'}}">
            <text class="info-label">作者:</text>
            <text class="info-value">{{item.noteAuthor || '未知'}}</text>
          </view>


          <!-- 驳回原因 -->
          <view class="audit-failure-reason" wx:if="{{(item.aiReviewResult && item.aiReviewResult.passed === false) || item.status === 'rejected' || item.status === 'manager_rejected' || item.status === 'client_verification_failed'}}">
            <text class="failure-label">审核失败原因：</text>
            <text class="failure-reason">{{item.rejectionReason || item.clientVerification && item.clientVerification.firstResult && item.clientVerification.firstResult.comment || (item.aiReviewResult && item.aiReviewResult.reasons && item.aiReviewResult.reasons.length > 0 ? item.aiReviewResult.reasons[item.aiReviewResult.reasons.length - 1] : '审核未通过')}}</text>
          </view>

          <!-- AI审核结果展示 - 已注释 -->
          <!-- <view class="ai-review-info" wx:if="{{item.aiReviewResult}}">
            <view class="ai-review-status">
              <text class="ai-label">机审结果：</text>
              <text class="ai-status {{item.aiReviewResult.passed ? 'passed' : 'failed'}}">
                {{item.aiReviewResult.passed ? '通过' : '未通过'}}
              </text>
            </view>
          </view> -->

          <!-- 持续检查结果 - 已注释 -->
          <!-- <view class="continuous-check-info" wx:if="{{item.continuousCheck}}">
            <view class="check-status">
              <text class="check-label">持续检查：</text>
              <text class="check-result {{item.continuousCheck.status === 'active' ? 'active' : 'failed'}}">
                {{item.continuousCheck.status === 'active' ? '正常' : '异常'}}
              </text>
              <text class="check-time" wx:if="{{item.continuousCheck.lastCheckTime}}">
                ({{item.continuousCheck.lastCheckTime.substring(5, 16).replace('T', ' ')}})
              </text>
            </view>
          </view> -->
        </view> <!-- 闭合 card-content -->
      </view> <!-- 闭合 review-card -->
    </block>

    <!-- 加载更多/到底提示 -->
    <view class="loading-more" wx:if="{{reviews.length > 0}}">
      <view wx:if="{{loading && hasMore}}" class="loading-indicator">
        <text class="loading-text">正在加载更多...</text>
      </view>
      <view wx:elif="{{!hasMore}}" class="no-more-data">
        <text class="no-more-text">--- 没有更多数据了 ---</text>
      </view>
    </view>
  </view>

  <!-- 📱 手机号授权模态框 -->
  <view class="phone-auth-modal" wx:if="{{showPhoneAuthModal}}">
    <view class="modal-mask" wx:if="{{!forceAuth}}" bindtap="closePhoneAuthModal"></view>
    <view class="modal-mask force-mask" wx:if="{{forceAuth}}"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">📱 手机号授权</text>
        <view class="close-btn" bindtap="closePhoneAuthModal">✕</view>
      </view>
      <view class="modal-body">
        <view class="auth-icon">📞</view>
        <view class="auth-text">
          <text wx:if="{{forceAuth}}">本小程序仅限内部员工使用，为完成身份验证，需要获取您的手机号信息。</text>
        </view>
        <view class="auth-tips">
          <text>手机号仅用于账号安全验证，不会用于其他用途</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel-btn" wx:if="{{!forceAuth}}" bindtap="closePhoneAuthModal">暂不授权</button>
        <button
          class="auth-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          📱 立即授权
        </button>
      </view>
    </view>
  </view>
</scroll-view>
