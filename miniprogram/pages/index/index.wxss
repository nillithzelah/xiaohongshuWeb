/* pages/index/index.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}


.container {
  padding-bottom: 40rpx;
  position: relative;
  height: 100vh; /* scroll-view 需要固定高度 */
}

/* 🔒 内部员工使用说明 */
.internal-notice {
  background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
  border: 1rpx solid #f39c12;
  border-radius: 12rpx;
  margin: 20rpx 30rpx;
  padding: 20rpx;
  position: relative;
}

.notice-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #856404;
  font-weight: 500;
  text-align: center;
}

/* 添加背景装饰 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(120, 219, 226, 0.08) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
}

/* 📢 公告栏样式 */
/* 公告栏 - 标题在正上方 */
.announcement-container {
  margin: 20rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 28rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.announcement-icon {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 8rpx;
  opacity: 0.9;
}

.announcement-swiper {
  height: 180rpx;
}

.announcement-item {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  height: 100%;
  padding: 0 16rpx;
}

.announcement-title {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 44rpx;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.announcement-content {
  font-size: 25rpx;
  color: #ffffff;
  line-height: 38rpx;
  opacity: 0.95;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
  word-break: break-all;
}

/* 👤 头部用户信息卡片 */
.header-card {
  background: #ffffff;
  padding: 32rpx;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  border: 1rpx solid #EBEEF5;
  position: relative;
  overflow: hidden;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.avatar:hover {
  transform: scale(1.05);
}

.user-text {
  margin-left: 24rpx;
}

.greeting {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 24rpx;
  color: #606266;
  margin-top: 8rpx;
}

/* 👥 审核员在线状态卡片 */
.auditor-status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.25);
}

.auditor-info {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.auditor-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.auditor-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.auditor-count {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.auditor-count.online {
  color: #ffd700;
}

.auditor-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.auditor-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.tips-dot {
  font-size: 20rpx;
  color: #ffd700;
  margin-right: 8rpx;
}

.tips-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 手机号授权按钮 */
.phone-auth-container {
  margin-left: 20rpx;
}

.phone-auth-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.phone-auth-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
}

/* 📋 列表样式 */
.list-container {
  padding: 0 30rpx;
}

.list-header {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  margin-left: 10rpx;
}

.review-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  border: 1rpx solid #EBEEF5;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
}

.review-card:hover {
  transform: translateY(-1rpx);
  border-color: #667eea;
}

.card-thumb-container {
  position: relative;
  flex-shrink: 0;
}

.card-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.completion-icon {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #52c41a;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.3);
}

.rejection-icon {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.3);
}

.card-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-type {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.time-row {
  margin-top: 8rpx;
}

/* 信息行样式 - 昵称和内容 */
.info-row {
  margin-top: 6rpx;
  justify-content: flex-start;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.comment-content {
  font-size: 24rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 内容行样式 */
.device-row {
  margin-top: 6rpx;
}

.device-name {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.content-row {
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}

.content-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.submit-time {
  font-size: 24rpx;
  color: #999;
}

.amount {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(255, 77, 79, 0.3);
}

/* 状态标签颜色 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.status-tag.pending {
  background: #e6f7ff;
  color: #1890ff;
}
.status-tag.mentor_approved {
  background: #fff7e6;
  color: #fa8c16;
}
.status-tag.manager_approved {
  background: #f6ffed;
  color: #52c41a;
}
.status-tag.completed {
  background: #f0f9ff;
  color: #52c41a;
}
.status-tag.rejected, .status-tag.manager_rejected {
  background: #fff2f0;
  color: #f5222d;
}

.reject-reason {
  margin-top: 12rpx;
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 22rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
}

/* 审核失败原因 */
.audit-failure-reason {
  margin-top: 8rpx;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
}

.failure-label {
  color: #fa8c16;
  font-size: 22rpx;
  font-weight: 500;
}

.failure-reason {
  color: #d46b08;
  font-size: 22rpx;
  line-height: 1.4;
}

/* AI审核结果 */
.ai-review-info {
  margin-top: 8rpx;
}

.ai-review-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ai-label {
  color: #666;
  font-size: 22rpx;
  font-weight: 500;
}

.ai-status {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.ai-status.passed {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.ai-status.failed {
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.ai-confidence {
  color: #999;
  font-size: 20rpx;
  margin-left: 4rpx;
}

/* 持续检查结果 */
.continuous-check-info {
  margin-top: 6rpx;
}

.check-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.check-label {
  color: #666;
  font-size: 22rpx;
  font-weight: 500;
}

.check-result {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.check-result.active {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.check-result.failed {
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.check-time {
  color: #999;
  font-size: 20rpx;
  margin-left: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 150rpx;
  margin-bottom: 20rpx;
}

.go-upload-btn {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0 60rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.go-upload-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.6s;
}

.go-upload-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 24rpx rgba(102, 126, 234, 0.4);
}

.go-upload-btn:hover::before {
  left: 100%;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
}

.loading-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.loading-text {
  color: #667eea;
  font-size: 24rpx;
  font-weight: 500;
}

.no-more-data {
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-more-text {
  color: #ccc;
  font-size: 24rpx;
  font-weight: 500;
}

/* 📱 手机号授权模态框 */
.phone-auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
  position: relative;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.close-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.modal-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.modal-body {
  padding: 40rpx 30rpx;
  text-align: center;
}

.auth-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  display: block;
}

.auth-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.auth-tips {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.modal-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.cancel-btn, .auth-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #ddd;
}

.cancel-btn:active {
  background: #e8e8e8;
  transform: scale(0.98);
}

.auth-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.auth-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 📱 设备审核状态卡片 */
.device-review-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 20rpx;
  border: 1rpx solid #EBEEF5;
  position: relative;
  overflow: hidden;
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.card-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.review-info {
  flex: 1;
}

.device-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.review-status {
  font-size: 24rpx;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.review-status.pending {
  background: #e6f7ff;
  color: #1890ff;
}

.review-status.ai_approved {
  background: #fff7e6;
  color: #fa8c16;
}

.review-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.review-status.rejected {
  background: #fff2f0;
  color: #f5222d;
}

.review-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.review-reason {
  font-size: 24rpx;
  color: #f5222d;
  background: #fff2f0;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.review-actions {
  margin-left: 20rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.retry-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

/* 🎁 持续检查奖励卡片样式 */
.continuous-check-card {
  background: linear-gradient(135deg, #fff9e6 0%, #fff 100%);
  border: 1rpx solid #ffd591;
  min-height: 180rpx;
}

.continuous-check-thumb {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ffd666 0%, #ffa940 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.continuous-check-icon {
  font-size: 50rpx;
}

.continuous-check-type {
  color: #d46b08;
}

.continuous-amount {
  color: #fa8c16;
  font-size: 36rpx;
}

.continuous-check-badge {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border: 1rpx solid #ffd591;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: inline-block;
}

.continuous-check-badge text {
  font-size: 22rpx;
  color: #d46b08;
}